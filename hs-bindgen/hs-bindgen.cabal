    HsBindgen.Cli.Preprocess
    HsBindgen.Cli.ToolSupport
    HsBindgen.Cli.ToolSupport.Literate
    Paths_hs_bindgen

  autogen-modules:    Paths_hs_bindgen

  -- Internal dependencies
  build-depends:
    , hs-bindgen
    , hs-bindgen:internal

  -- Inherited dependencies
  build-depends:
    , bytestring
    , containers
    , data-default
    , libclang-bindings

  -- External dependencies
  build-depends:
    , optparse-applicative  >=0.18  && <0.20
    , prettyprinter         >=1.7.1 && <1.8
    , text                  >=1.2   && <2.2

executable clang-ast-dump
  import:         lang
  main-is:        Main.hs
  hs-source-dirs: clang-ast-dump

  if flag(dev)
    buildable: True

  else
    buildable: False

  -- Internal dependencies
  build-depends:  hs-bindgen:internal

  -- Inherited dependencies
  build-depends:
    , containers
    , data-default
    , libclang-bindings
    , text

  -- External dependencies
  build-depends:  optparse-applicative >=0.18 && <0.20

