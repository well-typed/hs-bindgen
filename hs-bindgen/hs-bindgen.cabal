    HsBindgen.Internal.Macro.CExpr.Translation.Value
    HsBindgen.Internal.Macro.CExpr.Type
    HsBindgen.Internal.Macro.CExpr.Typecheck

  reexported-modules:
  other-extensions:   TemplateHaskellQuotes

  -- Internal dependencies
  build-depends:
    , c-expr-dsl
    , c-expr-runtime
    , hs-bindgen-runtime
    , hs-bindgen:internal

  -- Inherited dependencies
  build-depends:
    , containers
    , data-default
    , debruijn
    , fin
    , libclang-bindings
    , template-haskell
    , text
    , vec

executable hs-bindgen-cli
  import:             lang
  default-extensions: NoFieldSelectors
  main-is:            hs-bindgen-cli.hs
  hs-source-dirs:     app
  other-modules:
    HsBindgen.App
    HsBindgen.App.Output
    HsBindgen.Cli
    HsBindgen.Cli.BindingSpec
    HsBindgen.Cli.BindingSpec.StdLib
    HsBindgen.Cli.GenTests
    HsBindgen.Cli.Info
