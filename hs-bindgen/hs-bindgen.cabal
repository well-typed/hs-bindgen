  hs-source-dirs:     src
  exposed-modules:
    HsBindgen.Macro
    HsBindgen.TH

  other-modules:
    HsBindgen.Internal.Macro.CExpr
    HsBindgen.Internal.Macro.CExpr.Global
    HsBindgen.Internal.Macro.CExpr.Parse
    HsBindgen.Internal.Macro.CExpr.Resolution
