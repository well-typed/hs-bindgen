#!/usr/bin/env bash

set -e

usage() {
    echo "Usage: $(basename "$0") [FILE]"
    echo
    echo "If no FILE is provided, compile '*.pp.hs' files."
    echo "Skip expected failures."

}

failures=(
    # GCC compilation errors (error happens when parsing inlined C source).
    # None (Yay)!

    # GHC compilation errors.
    "macro_functions.pp.hs"  # Import error ("type" keyword required).
    "macro_in_fundecl.pp.hs" # "Illegal type" error.
    "macro_strings.pp.hs"    # "A section must be enclosed in parentheses" error
    "macro_types.pp.hs"      # "Illegal type" error.
    "typedef_vs_macro.pp.hs" # "Illegal type" error.
    "typenames.pp.hs"        # "Multiple declarations" error.
    "type_naturals.pp.hs"    # "Illegal type" error.
)

compile_one() {
    file="$1"
    echo "Compiling $file"
    cabal exec -- \
        ghc -fforce-recomp -optc \
        -I"../examples" \
        -I"../examples/failing" \
        -I"../examples/golden" \
        -I"../examples/golden-norust" \
        "$file"
}

compile_all() {
    for f in *.pp.hs; do
        if [[ " ${failures[*]} " =~ [[:space:]]${f}[[:space:]] ]]; then
            echo "Skipping test $f; expected failure"
        else
            compile_one "$f"
        fi
    done
}

# Ensure the build is up-to-date.
cabal build all

if [ $# -lt 1 ]; then
    compile_all
elif [ $# -eq 1 ]; then
    compile_one "$1"
else
    usage
fi
