{ mkDerivation, base, lib, QuickCheck, tasty, tasty-hunit
, tasty-quickcheck
}:
mkDerivation {
  pname = "hs-bindgen-test-runtime";
  version = "0.1.0";
  src = ../../hs-bindgen-test-runtime;
  libraryHaskellDepends = [
    base QuickCheck tasty-hunit tasty-quickcheck
  ];
  testHaskellDepends = [ base tasty tasty-hunit tasty-quickcheck ];
  description = "Library for testing bindings generated by hs-bindgen";
  license = lib.meta.getLicenseFromSpdxId "BSD-3-Clause";
}
